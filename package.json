{
  "name": "personalized-travel-system",
  "version": "1.0.0",
  "description": "个性化旅游系统",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "shared"
  ],
  "scripts": {
    "setup:data": "cd backend && npm run setup:data",
    "setup:data:with-covers": "cd backend && npm run setup:data:with-covers",
    "repair:data:arrays": "cd backend && npm run repair-data:arrays",
    "check:data": "cd backend && npm run check-data",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm test",
    "test:frontend": "cd frontend && npm test"
  },
  "keywords": [
    "travel",
    "recommendation",
    "path-planning"
  ],
  "author": "",
  "license": "MIT"
}
